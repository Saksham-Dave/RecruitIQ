<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RecruitIQ — Resume Screening System</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:ital,wght@0,300;0,400;1,300&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a0f;
    --surface: #111118;
    --surface2: #18181f;
    --border: #2a2a38;
    --border-glow: #3d3d5c;
    --accent: #7c6af7;
    --accent2: #f7706a;
    --accent3: #52e0b0;
    --text: #e8e8f0;
    --text-dim: #8888aa;
    --text-muted: #44445a;
    --gold: #f0c060;
    --radius: 12px;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* BACKGROUND */
  .bg-grid {
    position: fixed; inset: 0; z-index: 0;
    background-image:
      linear-gradient(rgba(124,106,247,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(124,106,247,0.04) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
  }
  .bg-glow {
    position: fixed; z-index: 0; pointer-events: none;
    border-radius: 50%; filter: blur(120px); opacity: 0.12;
  }
  .bg-glow-1 { width: 600px; height: 600px; background: var(--accent); top: -200px; left: -200px; }
  .bg-glow-2 { width: 400px; height: 400px; background: var(--accent2); bottom: -100px; right: -100px; }

  /* LAYOUT */
  .app { position: relative; z-index: 1; max-width: 1200px; margin: 0 auto; padding: 0 24px; }

  /* HEADER */
  header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 28px 0 24px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 40px;
  }
  .logo { display: flex; align-items: center; gap: 12px; }
  .logo-icon {
    width: 40px; height: 40px; background: linear-gradient(135deg, var(--accent), var(--accent2));
    border-radius: 10px; display: flex; align-items: center; justify-content: center;
    font-size: 18px;
  }
  .logo-text { font-family: 'Syne', sans-serif; font-size: 22px; font-weight: 800; letter-spacing: -0.5px; }
  .logo-text span { color: var(--accent); }
  .header-badge {
    font-family: 'DM Mono', monospace; font-size: 11px; color: var(--accent3);
    background: rgba(82,224,176,0.08); border: 1px solid rgba(82,224,176,0.2);
    padding: 4px 12px; border-radius: 20px; letter-spacing: 0.05em;
  }

  /* HERO */
  .hero { text-align: center; margin-bottom: 48px; }
  .hero h1 {
    font-family: 'Syne', sans-serif; font-size: clamp(32px, 5vw, 56px); font-weight: 800;
    line-height: 1.08; letter-spacing: -2px; margin-bottom: 16px;
  }
  .hero h1 em { font-style: normal; color: var(--accent); }
  .hero p { color: var(--text-dim); font-size: 17px; max-width: 520px; margin: 0 auto; line-height: 1.6; }

  /* STEP INDICATORS */
  .steps {
    display: flex; align-items: center; justify-content: center; gap: 0; margin-bottom: 40px;
  }
  .step {
    display: flex; align-items: center; gap: 10px; font-size: 13px; font-weight: 500;
    color: var(--text-muted); transition: color 0.3s;
  }
  .step.active { color: var(--text); }
  .step.done { color: var(--accent3); }
  .step-num {
    width: 28px; height: 28px; border-radius: 50%; border: 1.5px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    font-family: 'DM Mono', monospace; font-size: 12px; transition: all 0.3s;
  }
  .step.active .step-num { border-color: var(--accent); background: rgba(124,106,247,0.15); color: var(--accent); }
  .step.done .step-num { border-color: var(--accent3); background: rgba(82,224,176,0.15); color: var(--accent3); }
  .step-line { width: 48px; height: 1px; background: var(--border); margin: 0 8px; }

  /* PANELS */
  .panel {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 28px; margin-bottom: 24px;
    transition: border-color 0.3s;
  }
  .panel:hover { border-color: var(--border-glow); }
  .panel-header {
    display: flex; align-items: center; gap: 10px; margin-bottom: 20px;
  }
  .panel-icon {
    width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 15px;
  }
  .panel-icon.purple { background: rgba(124,106,247,0.15); }
  .panel-icon.red { background: rgba(247,112,106,0.15); }
  .panel-icon.green { background: rgba(82,224,176,0.15); }
  .panel-title { font-family: 'Syne', sans-serif; font-size: 16px; font-weight: 700; }
  .panel-sub { font-size: 12px; color: var(--text-dim); font-family: 'DM Mono', monospace; }

  /* JOB SECTION */
  .job-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media(max-width: 640px) { .job-grid { grid-template-columns: 1fr; } }

  .field { margin-bottom: 16px; }
  .field label { display: block; font-size: 12px; font-weight: 500; color: var(--text-dim); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.06em; }
  .field input, .field textarea, .field select {
    width: 100%; background: var(--surface2); border: 1px solid var(--border);
    border-radius: 8px; padding: 10px 14px; color: var(--text); font-family: 'DM Sans', sans-serif;
    font-size: 14px; outline: none; transition: border-color 0.2s, box-shadow 0.2s;
    resize: vertical;
  }
  .field input:focus, .field textarea:focus, .field select:focus {
    border-color: var(--accent); box-shadow: 0 0 0 3px rgba(124,106,247,0.12);
  }
  .field textarea { min-height: 90px; }
  .field select option { background: var(--surface2); }

  /* SKILLS TAGS */
  .skills-wrap { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 6px; }
  .skill-tag {
    background: rgba(124,106,247,0.12); border: 1px solid rgba(124,106,247,0.3);
    color: var(--accent); border-radius: 6px; padding: 4px 10px; font-size: 12px;
    font-family: 'DM Mono', monospace; display: flex; align-items: center; gap: 6px;
    cursor: pointer; transition: background 0.2s;
  }
  .skill-tag:hover { background: rgba(124,106,247,0.22); }
  .skill-tag .rm { opacity: 0.6; font-size: 14px; line-height: 1; }
  .skill-add { display: flex; gap: 8px; margin-top: 8px; }
  .skill-add input { flex: 1; }
  .btn-ghost {
    background: transparent; border: 1px solid var(--border); color: var(--text-dim);
    border-radius: 8px; padding: 8px 14px; font-size: 13px; cursor: pointer;
    font-family: 'DM Sans', sans-serif; transition: all 0.2s; white-space: nowrap;
  }
  .btn-ghost:hover { border-color: var(--accent); color: var(--accent); }

  /* RESUME UPLOAD */
  .upload-area {
    border: 2px dashed var(--border); border-radius: 10px;
    padding: 36px; text-align: center; cursor: pointer;
    transition: all 0.25s; position: relative;
  }
  .upload-area:hover, .upload-area.drag-over {
    border-color: var(--accent); background: rgba(124,106,247,0.05);
  }
  .upload-area input[type="file"] { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
  .upload-icon { font-size: 32px; margin-bottom: 10px; display: block; }
  .upload-title { font-weight: 600; font-size: 15px; margin-bottom: 4px; }
  .upload-sub { font-size: 13px; color: var(--text-dim); }

  .resume-list { margin-top: 16px; display: flex; flex-direction: column; gap: 10px; }
  .resume-item {
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: 8px; padding: 12px 16px;
    display: flex; align-items: center; gap: 12px;
    animation: slideIn 0.3s ease;
  }
  @keyframes slideIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  .resume-icon { font-size: 20px; }
  .resume-info { flex: 1; }
  .resume-name { font-size: 14px; font-weight: 500; }
  .resume-size { font-size: 11px; color: var(--text-dim); font-family: 'DM Mono', monospace; }
  .resume-status {
    font-size: 11px; padding: 3px 8px; border-radius: 4px; font-family: 'DM Mono', monospace;
  }
  .resume-status.pending { background: rgba(240,192,96,0.12); color: var(--gold); border: 1px solid rgba(240,192,96,0.25); }
  .resume-status.done { background: rgba(82,224,176,0.12); color: var(--accent3); border: 1px solid rgba(82,224,176,0.25); }
  .resume-status.analyzing { background: rgba(124,106,247,0.12); color: var(--accent); border: 1px solid rgba(124,106,247,0.25); }
  .rm-resume { background: none; border: none; color: var(--text-muted); cursor: pointer; font-size: 16px; transition: color 0.2s; }
  .rm-resume:hover { color: var(--accent2); }

  /* ANALYZE BUTTON */
  .analyze-wrap { text-align: center; margin: 32px 0; }
  .btn-analyze {
    background: linear-gradient(135deg, var(--accent), #9a8af7);
    color: white; border: none; border-radius: 10px; padding: 14px 40px;
    font-family: 'Syne', sans-serif; font-size: 16px; font-weight: 700;
    cursor: pointer; transition: all 0.25s; display: inline-flex; align-items: center; gap: 10px;
    box-shadow: 0 4px 24px rgba(124,106,247,0.3);
  }
  .btn-analyze:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(124,106,247,0.45); }
  .btn-analyze:active { transform: translateY(0); }
  .btn-analyze:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
  .btn-analyze .spinner {
    width: 16px; height: 16px; border: 2px solid rgba(255,255,255,0.3);
    border-top-color: white; border-radius: 50%; animation: spin 0.7s linear infinite; display: none;
  }
  .btn-analyze.loading .spinner { display: block; }
  .btn-analyze.loading .btn-text::after { content: '...'; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* PROGRESS */
  .progress-panel {
    background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius);
    padding: 20px 28px; margin-bottom: 24px; display: none;
  }
  .progress-label { font-size: 13px; color: var(--text-dim); margin-bottom: 10px; display: flex; justify-content: space-between; }
  .progress-bar { height: 6px; background: var(--surface2); border-radius: 3px; overflow: hidden; }
  .progress-fill { height: 100%; background: linear-gradient(90deg, var(--accent), var(--accent3)); border-radius: 3px; transition: width 0.4s ease; width: 0%; }
  .progress-log { margin-top: 12px; font-family: 'DM Mono', monospace; font-size: 11px; color: var(--text-dim); }
  .log-entry { padding: 2px 0; opacity: 0; animation: fadeLog 0.3s forwards; }
  @keyframes fadeLog { to { opacity: 1; } }

  /* RESULTS */
  .results-section { display: none; }
  .results-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 24px; flex-wrap: gap;
  }
  .results-title { font-family: 'Syne', sans-serif; font-size: 24px; font-weight: 800; }
  .results-count { font-size: 13px; color: var(--text-dim); font-family: 'DM Mono', monospace; }
  .results-filters { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 20px; }
  .filter-btn {
    background: var(--surface2); border: 1px solid var(--border); color: var(--text-dim);
    border-radius: 6px; padding: 6px 14px; font-size: 12px; cursor: pointer;
    font-family: 'DM Mono', monospace; transition: all 0.2s;
  }
  .filter-btn:hover, .filter-btn.active { border-color: var(--accent); color: var(--accent); background: rgba(124,106,247,0.1); }

  .result-cards { display: flex; flex-direction: column; gap: 16px; }
  .result-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); overflow: hidden;
    animation: cardIn 0.4s ease both;
    transition: border-color 0.25s, transform 0.2s;
  }
  .result-card:hover { border-color: var(--border-glow); transform: translateY(-1px); }
  @keyframes cardIn { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: none; } }

  .card-top { padding: 20px 24px; display: flex; align-items: flex-start; gap: 16px; }
  .card-rank {
    min-width: 44px; height: 44px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Syne', sans-serif; font-size: 18px; font-weight: 800;
  }
  .rank-1 { background: rgba(240,192,96,0.15); color: var(--gold); border: 1px solid rgba(240,192,96,0.3); }
  .rank-2 { background: rgba(200,200,220,0.1); color: #b0b0cc; border: 1px solid rgba(200,200,220,0.2); }
  .rank-3 { background: rgba(180,120,80,0.12); color: #c08060; border: 1px solid rgba(180,120,80,0.25); }
  .rank-other { background: var(--surface2); color: var(--text-dim); border: 1px solid var(--border); }

  .card-main { flex: 1; }
  .card-name { font-family: 'Syne', sans-serif; font-size: 17px; font-weight: 700; margin-bottom: 4px; }
  .card-filename { font-size: 12px; color: var(--text-dim); font-family: 'DM Mono', monospace; }
  .card-score-wrap { display: flex; align-items: center; gap: 16px; margin-top: 12px; }

  .score-circle {
    position: relative; width: 64px; height: 64px;
  }
  .score-circle svg { transform: rotate(-90deg); }
  .score-circle .track { fill: none; stroke: var(--surface2); stroke-width: 5; }
  .score-circle .fill { fill: none; stroke-width: 5; stroke-linecap: round; transition: stroke-dashoffset 1.2s cubic-bezier(.4,0,.2,1); }
  .score-label {
    position: absolute; inset: 0; display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 800; line-height: 1;
  }
  .score-label span { font-size: 9px; font-weight: 400; color: var(--text-dim); font-family: 'DM Mono', monospace; }

  .card-metrics { display: grid; grid-template-columns: repeat(3,1fr); gap: 10px; flex: 1; }
  .metric { background: var(--surface2); border-radius: 8px; padding: 10px 12px; }
  .metric-label { font-size: 10px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 4px; }
  .metric-val { font-family: 'Syne', sans-serif; font-size: 18px; font-weight: 700; }
  .metric-bar { height: 3px; background: var(--border); border-radius: 2px; margin-top: 6px; overflow: hidden; }
  .metric-bar-fill { height: 100%; border-radius: 2px; transition: width 1s ease; }

  .card-recommend {
    padding: 0 24px 16px; display: flex; align-items: center; gap: 10px;
  }
  .recommend-badge {
    font-size: 11px; font-family: 'DM Mono', monospace; padding: 4px 10px; border-radius: 5px;
  }
  .recommend-badge.strong { background: rgba(82,224,176,0.12); color: var(--accent3); border: 1px solid rgba(82,224,176,0.25); }
  .recommend-badge.consider { background: rgba(124,106,247,0.12); color: var(--accent); border: 1px solid rgba(124,106,247,0.25); }
  .recommend-badge.maybe { background: rgba(240,192,96,0.12); color: var(--gold); border: 1px solid rgba(240,192,96,0.25); }
  .recommend-badge.no { background: rgba(247,112,106,0.1); color: var(--accent2); border: 1px solid rgba(247,112,106,0.22); }

  .card-detail { border-top: 1px solid var(--border); max-height: 0; overflow: hidden; transition: max-height 0.4s ease; }
  .card-detail.open { max-height: 600px; }
  .card-detail-inner { padding: 20px 24px; }
  .detail-section { margin-bottom: 18px; }
  .detail-section h4 { font-size: 12px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 10px; }
  .detail-text { font-size: 14px; line-height: 1.65; color: var(--text-dim); }
  .skills-found { display: flex; flex-wrap: wrap; gap: 6px; }
  .skill-found {
    font-size: 11px; font-family: 'DM Mono', monospace; padding: 3px 8px; border-radius: 4px;
  }
  .skill-found.match { background: rgba(82,224,176,0.12); color: var(--accent3); border: 1px solid rgba(82,224,176,0.2); }
  .skill-found.miss { background: rgba(247,112,106,0.08); color: var(--accent2); border: 1px solid rgba(247,112,106,0.15); }
  .toggle-detail {
    background: none; border: none; color: var(--text-dim); font-size: 12px;
    cursor: pointer; font-family: 'DM Mono', monospace; padding: 0; transition: color 0.2s;
    display: flex; align-items: center; gap: 5px;
  }
  .toggle-detail:hover { color: var(--accent); }

  /* EMPTY STATE */
  .empty-state {
    text-align: center; padding: 48px 24px; color: var(--text-muted);
  }
  .empty-state-icon { font-size: 48px; margin-bottom: 12px; display: block; opacity: 0.4; }

  /* SUMMARY BAR */
  .summary-bar {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 28px;
  }
  .summary-card {
    background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 16px 20px;
  }
  .summary-card-label { font-size: 11px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 6px; }
  .summary-card-val { font-family: 'Syne', sans-serif; font-size: 28px; font-weight: 800; }
  @media(max-width: 640px) { .summary-bar { grid-template-columns: repeat(2,1fr); } }

  /* TOAST */
  .toast {
    position: fixed; bottom: 24px; right: 24px; background: var(--surface);
    border: 1px solid var(--border); border-radius: 10px; padding: 14px 20px;
    font-size: 14px; z-index: 999; display: none; align-items: center; gap: 10px;
    animation: toastIn 0.3s ease;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }
  @keyframes toastIn { from { transform: translateY(12px); opacity: 0; } to { transform: none; opacity: 1; } }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--border-glow); }
</style>
</head>
<body>
<div class="bg-grid"></div>
<div class="bg-glow bg-glow-1"></div>
<div class="bg-glow bg-glow-2"></div>

<div class="app">
  <header>
    <div class="logo">
      <div class="logo-icon">🎯</div>
      <div class="logo-text">Recruit<span>IQ</span></div>
    </div>
    <div class="header-badge">AI-Powered Screening</div>
  </header>

  <div class="hero">
    <h1>Screen resumes <em>intelligently</em><br>with AI analysis</h1>
    <p>Define your job requirements, upload candidate resumes, and let AI rank and evaluate each one instantly.</p>
  </div>

  <!-- STEPS -->
  <div class="steps">
    <div class="step active" id="step1">
      <div class="step-num">1</div>
      Job Details
    </div>
    <div class="step-line"></div>
    <div class="step" id="step2">
      <div class="step-num">2</div>
      Upload Resumes
    </div>
    <div class="step-line"></div>
    <div class="step" id="step3">
      <div class="step-num">3</div>
      AI Results
    </div>
  </div>

  <!-- JOB DESCRIPTION PANEL -->
  <div class="panel" id="jobPanel">
    <div class="panel-header">
      <div class="panel-icon purple">📋</div>
      <div>
        <div class="panel-title">Job Requirements</div>
        <div class="panel-sub">Define what you're looking for</div>
      </div>
    </div>
    <div class="job-grid">
      <div class="field">
        <label>Job Title *</label>
        <input type="text" id="jobTitle" placeholder="e.g. Senior Frontend Engineer" />
      </div>
      <div class="field">
        <label>Seniority Level</label>
        <select id="seniority">
          <option value="junior">Junior (0–2 yrs)</option>
          <option value="mid" selected>Mid-level (2–5 yrs)</option>
          <option value="senior">Senior (5–8 yrs)</option>
          <option value="lead">Lead / Staff (8+ yrs)</option>
        </select>
      </div>
    </div>
    <div class="field">
      <label>Job Description</label>
      <textarea id="jobDesc" placeholder="Paste the full job description or key responsibilities..."></textarea>
    </div>
    <div class="field">
      <label>Required Skills</label>
      <div class="skills-wrap" id="skillsWrap"></div>
      <div class="skill-add">
        <input type="text" id="skillInput" placeholder="Add a skill (press Enter)" style="min-height:unset;" />
        <button class="btn-ghost" onclick="addSkill()">+ Add</button>
      </div>
    </div>
    <div class="job-grid">
      <div class="field">
        <label>Minimum Experience (years)</label>
        <input type="number" id="minExp" placeholder="e.g. 3" min="0" max="20" value="2" />
      </div>
      <div class="field">
        <label>Education Requirement</label>
        <select id="education">
          <option value="none">No preference</option>
          <option value="bachelors" selected>Bachelor's degree</option>
          <option value="masters">Master's degree</option>
          <option value="phd">PhD</option>
        </select>
      </div>
    </div>
  </div>

  <!-- RESUME UPLOAD PANEL -->
  <div class="panel" id="uploadPanel">
    <div class="panel-header">
      <div class="panel-icon red">📄</div>
      <div>
        <div class="panel-title">Upload Resumes</div>
        <div class="panel-sub">Supports .txt, .pdf (text), .doc text formats</div>
      </div>
    </div>
    <div class="upload-area" id="uploadArea">
      <input type="file" id="fileInput" multiple accept=".txt,.pdf,.doc,.docx" />
      <span class="upload-icon">📁</span>
      <div class="upload-title">Drop resumes here or click to browse</div>
      <div class="upload-sub">Multiple files supported · Text-based files work best</div>
    </div>
    <div class="resume-list" id="resumeList"></div>
    <!-- PASTE OPTION -->
    <div style="margin-top:16px;">
      <button class="btn-ghost" onclick="togglePaste()" id="pasteToggleBtn">✏️ Or paste resume text manually</button>
      <div id="pasteArea" style="display:none; margin-top:12px;">
        <div class="field">
          <label>Candidate Name</label>
          <input type="text" id="pasteName" placeholder="e.g. John Smith" />
        </div>
        <div class="field">
          <label>Resume Text</label>
          <textarea id="pasteText" rows="8" placeholder="Paste the full resume text here..."></textarea>
        </div>
        <button class="btn-ghost" onclick="addPastedResume()">➕ Add Resume</button>
      </div>
    </div>
  </div>

  <!-- ANALYZE BUTTON -->
  <div class="analyze-wrap">
    <button class="btn-analyze" id="analyzeBtn" onclick="startAnalysis()">
      <div class="spinner"></div>
      <span class="btn-text">✨ Screen Resumes with AI</span>
    </button>
    <div style="margin-top:10px; font-size:12px; color:var(--text-muted);" id="analyzeHint">Add job details and at least 1 resume to begin</div>
  </div>

  <!-- PROGRESS -->
  <div class="progress-panel" id="progressPanel">
    <div class="progress-label">
      <span id="progressText">Initializing analysis...</span>
      <span id="progressPct">0%</span>
    </div>
    <div class="progress-bar">
      <div class="progress-fill" id="progressFill"></div>
    </div>
    <div class="progress-log" id="progressLog"></div>
  </div>

  <!-- RESULTS -->
  <div class="results-section" id="resultsSection">
    <div class="results-header">
      <div>
        <div class="results-title">Screening Results</div>
        <div class="results-count" id="resultsCount"></div>
      </div>
      <button class="btn-ghost" onclick="resetAll()">↩ New Screening</button>
    </div>

    <div class="summary-bar" id="summaryBar"></div>

    <div class="results-filters">
      <button class="filter-btn active" onclick="filterResults('all', this)">All Candidates</button>
      <button class="filter-btn" onclick="filterResults('strong', this)">Strong Hire ✅</button>
      <button class="filter-btn" onclick="filterResults('consider', this)">Consider 🔍</button>
      <button class="filter-btn" onclick="filterResults('maybe', this)">Maybe ⚠️</button>
      <button class="filter-btn" onclick="filterResults('no', this)">Not a Fit ❌</button>
    </div>

    <div class="result-cards" id="resultCards"></div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
let skills = [];
let resumes = [];
let results = [];
let allResults = [];

// DEFAULT SKILLS
['JavaScript', 'React', 'TypeScript', 'CSS', 'Node.js'].forEach(s => addSkill(s));

document.getElementById('skillInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') { e.preventDefault(); addSkill(); }
});

function addSkill(val) {
  const input = document.getElementById('skillInput');
  const skill = (val || input.value).trim();
  if (!skill || skills.includes(skill)) return;
  skills.push(skill);
  if (!val) input.value = '';
  renderSkills();
}

function removeSkill(s) {
  skills = skills.filter(x => x !== s);
  renderSkills();
}

function renderSkills() {
  const wrap = document.getElementById('skillsWrap');
  wrap.innerHTML = skills.map(s => `
    <span class="skill-tag" onclick="removeSkill('${s.replace(/'/g,"\\'")}')">
      ${s} <span class="rm">×</span>
    </span>
  `).join('');
}

// FILE UPLOAD
const uploadArea = document.getElementById('uploadArea');
const fileInput = document.getElementById('fileInput');
uploadArea.addEventListener('dragover', e => { e.preventDefault(); uploadArea.classList.add('drag-over'); });
uploadArea.addEventListener('dragleave', () => uploadArea.classList.remove('drag-over'));
uploadArea.addEventListener('drop', e => {
  e.preventDefault(); uploadArea.classList.remove('drag-over');
  handleFiles(e.dataTransfer.files);
});
fileInput.addEventListener('change', e => handleFiles(e.target.files));

function handleFiles(files) {
  Array.from(files).forEach(file => {
    const reader = new FileReader();
    reader.onload = e => {
      resumes.push({ id: Date.now() + Math.random(), name: file.name.replace(/\.[^.]+$/, ''), filename: file.name, text: e.target.result, size: file.size, status: 'pending' });
      renderResumeList();
    };
    reader.readAsText(file);
  });
}

function togglePaste() {
  const area = document.getElementById('pasteArea');
  const btn = document.getElementById('pasteToggleBtn');
  if (area.style.display === 'none') { area.style.display = 'block'; btn.textContent = '✕ Close paste area'; }
  else { area.style.display = 'none'; btn.textContent = '✏️ Or paste resume text manually'; }
}

function addPastedResume() {
  const name = document.getElementById('pasteName').value.trim() || 'Unnamed Candidate';
  const text = document.getElementById('pasteText').value.trim();
  if (!text) { showToast('⚠️ Please paste some resume text.'); return; }
  resumes.push({ id: Date.now(), name, filename: name + '.txt', text, size: text.length, status: 'pending' });
  document.getElementById('pasteName').value = '';
  document.getElementById('pasteText').value = '';
  renderResumeList();
  showToast('✅ Resume added!');
}

function renderResumeList() {
  const list = document.getElementById('resumeList');
  if (!resumes.length) { list.innerHTML = ''; updateHint(); return; }
  list.innerHTML = resumes.map(r => `
    <div class="resume-item" id="ri-${r.id}">
      <span class="resume-icon">📄</span>
      <div class="resume-info">
        <div class="resume-name">${r.name}</div>
        <div class="resume-size">${r.filename} · ${(r.size/1024).toFixed(1)} KB</div>
      </div>
      <span class="resume-status ${r.status}">${r.status}</span>
      <button class="rm-resume" onclick="removeResume(${r.id})">×</button>
    </div>
  `).join('');
  updateSteps();
  updateHint();
}

function removeResume(id) {
  resumes = resumes.filter(r => r.id !== id);
  renderResumeList();
}

function updateHint() {
  const hint = document.getElementById('analyzeHint');
  const btn = document.getElementById('analyzeBtn');
  const title = document.getElementById('jobTitle').value.trim();
  if (!resumes.length) { hint.textContent = 'Add job details and at least 1 resume to begin'; btn.disabled = true; }
  else if (!title) { hint.textContent = 'Please add a job title to continue'; btn.disabled = true; }
  else { hint.textContent = `Ready to screen ${resumes.length} resume${resumes.length > 1 ? 's' : ''}`; btn.disabled = false; }
}
document.getElementById('jobTitle').addEventListener('input', updateHint);
updateHint();

function updateSteps() {
  const s1 = document.getElementById('step1');
  const s2 = document.getElementById('step2');
  if (document.getElementById('jobTitle').value.trim()) { s1.classList.remove('active'); s1.classList.add('done'); }
  if (resumes.length) { s2.classList.add('active'); }
}

function removeResume(id) {
  resumes = resumes.filter(r => r.id !== id);
  renderResumeList();
}

// === AI ANALYSIS ===
async function startAnalysis() {
  const title = document.getElementById('jobTitle').value.trim();
  if (!title) { showToast('⚠️ Please enter a job title.'); return; }
  if (!resumes.length) { showToast('⚠️ Please upload at least one resume.'); return; }

  const btn = document.getElementById('analyzeBtn');
  btn.classList.add('loading'); btn.disabled = true;

  document.getElementById('progressPanel').style.display = 'block';
  document.getElementById('resultsSection').style.display = 'none';
  document.getElementById('progressLog').innerHTML = '';
  setProgress(0, 'Starting AI engine...');

  const jobCtx = {
    title,
    description: document.getElementById('jobDesc').value,
    skills,
    minExp: document.getElementById('minExp').value,
    seniority: document.getElementById('seniority').value,
    education: document.getElementById('education').value
  };

  results = [];
  let done = 0;

  for (const resume of resumes) {
    setResumeStatus(resume.id, 'analyzing');
    logEntry(`🔍 Analyzing: ${resume.name}...`);

    try {
      const result = await analyzeResume(resume, jobCtx);
      result.filename = resume.filename;
      results.push(result);
    } catch(e) {
      results.push({ name: resume.name, filename: resume.filename, overallScore: 0, skillScore: 0, expScore: 0, eduScore: 0, recommendation: 'no', summary: 'Analysis failed: ' + e.message, matchedSkills: [], missingSkills: skills, experience: 'Unknown' });
    }

    done++;
    setResumeStatus(resume.id, 'done');
    setProgress(Math.round((done / resumes.length) * 90), `Processed ${done}/${resumes.length} resumes`);
  }

  logEntry('📊 Ranking candidates...');
  results.sort((a,b) => b.overallScore - a.overallScore);
  allResults = [...results];

  setProgress(100, 'Analysis complete!');
  setTimeout(() => {
    btn.classList.remove('loading'); btn.disabled = false;
    document.getElementById('progressPanel').style.display = 'none';
    document.getElementById('step3').classList.add('active', 'done');
    showResults();
  }, 600);
}

async function analyzeResume(resume, job) {
  const prompt = `You are an expert HR recruiter and resume screener. Analyze this resume against the job requirements and return ONLY a JSON object (no markdown, no explanation).

JOB REQUIREMENTS:
- Title: ${job.title}
- Seniority: ${job.seniority}
- Required Skills: ${job.skills.join(', ') || 'Not specified'}
- Min Experience: ${job.minExp} years
- Education: ${job.education}
- Description: ${job.description || 'Not provided'}

RESUME TEXT:
${resume.text.substring(0, 3000)}

Return this exact JSON structure (no extra text):
{
  "name": "candidate full name from resume, or use '${resume.name}' if not found",
  "overallScore": <integer 0-100>,
  "skillScore": <integer 0-100>,
  "expScore": <integer 0-100>,
  "eduScore": <integer 0-100>,
  "experience": "<extracted total years or estimate like '3 years'>",
  "matchedSkills": ["skill1","skill2"],
  "missingSkills": ["skill1","skill2"],
  "recommendation": "<one of: strong|consider|maybe|no>",
  "strengths": "<2-3 sentences about top strengths>",
  "concerns": "<1-2 sentences about gaps or concerns>",
  "summary": "<2-3 sentence professional summary of candidate fit>"
}`;

  const resp = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      model: 'claude-sonnet-4-20250514',
      max_tokens: 1000,
      messages: [{ role: 'user', content: prompt }]
    })
  });

  if (!resp.ok) throw new Error('API error ' + resp.status);
  const data = await resp.json();
  const text = data.content.map(b => b.text || '').join('').trim();
  const clean = text.replace(/```json|```/g, '').trim();
  const parsed = JSON.parse(clean);
  if (!parsed.name) parsed.name = resume.name;
  return parsed;
}

function setProgress(pct, text) {
  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('progressText').textContent = text;
  document.getElementById('progressPct').textContent = pct + '%';
}

function logEntry(msg) {
  const log = document.getElementById('progressLog');
  const el = document.createElement('div');
  el.className = 'log-entry';
  el.textContent = '> ' + msg;
  log.appendChild(el);
  log.scrollTop = log.scrollHeight;
}

function setResumeStatus(id, status) {
  resumes = resumes.map(r => r.id === id ? {...r, status} : r);
  renderResumeList();
}

function showResults() {
  const section = document.getElementById('resultsSection');
  section.style.display = 'block';
  section.scrollIntoView({ behavior: 'smooth', block: 'start' });

  const strong = results.filter(r => r.recommendation === 'strong').length;
  const consider = results.filter(r => r.recommendation === 'consider').length;
  const maybe = results.filter(r => r.recommendation === 'maybe').length;
  const no = results.filter(r => r.recommendation === 'no').length;
  const avg = Math.round(results.reduce((s,r) => s + r.overallScore, 0) / results.length);

  document.getElementById('summaryBar').innerHTML = `
    <div class="summary-card"><div class="summary-card-label">Total Screened</div><div class="summary-card-val">${results.length}</div></div>
    <div class="summary-card"><div class="summary-card-label">Strong Hire</div><div class="summary-card-val" style="color:var(--accent3)">${strong}</div></div>
    <div class="summary-card"><div class="summary-card-label">To Consider</div><div class="summary-card-val" style="color:var(--accent)">${consider}</div></div>
    <div class="summary-card"><div class="summary-card-label">Avg Score</div><div class="summary-card-val" style="color:var(--gold)">${avg}</div></div>
  `;

  document.getElementById('resultsCount').textContent = `${results.length} candidate${results.length > 1 ? 's' : ''} ranked by AI score`;
  renderCards(results);
}

function filterResults(type, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const filtered = type === 'all' ? allResults : allResults.filter(r => r.recommendation === type);
  renderCards(filtered);
}

function renderCards(data) {
  const container = document.getElementById('resultCards');
  if (!data.length) {
    container.innerHTML = '<div class="empty-state"><span class="empty-state-icon">🔍</span><div>No candidates match this filter</div></div>';
    return;
  }

  container.innerHTML = data.map((r, i) => {
    const rank = i + 1;
    const rankClass = rank === 1 ? 'rank-1' : rank === 2 ? 'rank-2' : rank === 3 ? 'rank-3' : 'rank-other';
    const recBadge = { strong: ['strong', '✅ Strong Hire'], consider: ['consider', '🔍 Consider'], maybe: ['maybe', '⚠️ Maybe'], no: ['no', '❌ Not a Fit'] }[r.recommendation] || ['no', '❌ Not a Fit'];
    const skillColor = r.skillScore >= 70 ? '#52e0b0' : r.skillScore >= 40 ? '#f0c060' : '#f7706a';
    const expColor = r.expScore >= 70 ? '#52e0b0' : r.expScore >= 40 ? '#f0c060' : '#f7706a';
    const eduColor = r.eduScore >= 70 ? '#52e0b0' : r.eduScore >= 40 ? '#7c6af7' : '#f7706a';
    const circleColor = r.overallScore >= 75 ? '#52e0b0' : r.overallScore >= 50 ? '#7c6af7' : r.overallScore >= 30 ? '#f0c060' : '#f7706a';
    const circ = 2 * Math.PI * 27;
    const dash = circ - (circ * r.overallScore / 100);

    const matchedSkillsHtml = (r.matchedSkills || []).map(s => `<span class="skill-found match">✓ ${s}</span>`).join('');
    const missSkillsHtml = (r.missingSkills || []).map(s => `<span class="skill-found miss">✗ ${s}</span>`).join('');

    return `
    <div class="result-card" style="animation-delay:${i*0.07}s">
      <div class="card-top">
        <div class="card-rank ${rankClass}">#${rank}</div>
        <div class="card-main">
          <div class="card-name">${r.name || 'Unknown Candidate'}</div>
          <div class="card-filename">${r.filename} · ${r.experience || 'exp. unknown'}</div>
          <div class="card-score-wrap">
            <div class="score-circle">
              <svg width="64" height="64" viewBox="0 0 64 64">
                <circle class="track" cx="32" cy="32" r="27"/>
                <circle class="fill" cx="32" cy="32" r="27"
                  stroke="${circleColor}"
                  stroke-dasharray="${circ}"
                  stroke-dashoffset="${circ}"
                  data-target="${dash}"
                  id="arc-${i}"/>
              </svg>
              <div class="score-label">${r.overallScore}<span>/ 100</span></div>
            </div>
            <div class="card-metrics">
              <div class="metric">
                <div class="metric-label">Skills</div>
                <div class="metric-val" style="color:${skillColor}">${r.skillScore}</div>
                <div class="metric-bar"><div class="metric-bar-fill" style="width:0%;background:${skillColor}" data-w="${r.skillScore}%"></div></div>
              </div>
              <div class="metric">
                <div class="metric-label">Exp.</div>
                <div class="metric-val" style="color:${expColor}">${r.expScore}</div>
                <div class="metric-bar"><div class="metric-bar-fill" style="width:0%;background:${expColor}" data-w="${r.expScore}%"></div></div>
              </div>
              <div class="metric">
                <div class="metric-label">Edu.</div>
                <div class="metric-val" style="color:${eduColor}">${r.eduScore}</div>
                <div class="metric-bar"><div class="metric-bar-fill" style="width:0%;background:${eduColor}" data-w="${r.eduScore}%"></div></div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="card-recommend">
        <span class="recommend-badge ${recBadge[0]}">${recBadge[1]}</span>
        <button class="toggle-detail" onclick="toggleDetail(this)">▸ View AI Analysis</button>
      </div>
      <div class="card-detail">
        <div class="card-detail-inner">
          <div class="detail-section">
            <h4>AI Summary</h4>
            <div class="detail-text">${r.summary || '—'}</div>
          </div>
          <div class="detail-section">
            <h4>Strengths</h4>
            <div class="detail-text" style="color:var(--accent3)">${r.strengths || '—'}</div>
          </div>
          <div class="detail-section">
            <h4>Concerns</h4>
            <div class="detail-text" style="color:var(--accent2)">${r.concerns || '—'}</div>
          </div>
          ${matchedSkillsHtml || missSkillsHtml ? `
          <div class="detail-section">
            <h4>Skills Match</h4>
            <div class="skills-found">${matchedSkillsHtml}${missSkillsHtml}</div>
          </div>` : ''}
        </div>
      </div>
    </div>`;
  }).join('');

  // Animate arcs + bars after render
  requestAnimationFrame(() => {
    document.querySelectorAll('[id^="arc-"]').forEach(el => {
      const target = parseFloat(el.getAttribute('data-target'));
      setTimeout(() => { el.style.strokeDashoffset = target; el.style.transition = 'stroke-dashoffset 1.2s cubic-bezier(.4,0,.2,1)'; }, 100);
    });
    document.querySelectorAll('.metric-bar-fill').forEach(el => {
      const w = el.getAttribute('data-w');
      setTimeout(() => { el.style.width = w; el.style.transition = 'width 1s ease'; }, 200);
    });
  });
}

function toggleDetail(btn) {
  const detail = btn.closest('.result-card').querySelector('.card-detail');
  const open = detail.classList.toggle('open');
  btn.textContent = open ? '▾ Hide AI Analysis' : '▸ View AI Analysis';
}

function resetAll() {
  results = []; allResults = []; resumes = [];
  renderResumeList();
  document.getElementById('resultsSection').style.display = 'none';
  document.getElementById('progressPanel').style.display = 'none';
  document.querySelectorAll('.step').forEach(s => { s.classList.remove('done'); });
  document.getElementById('step1').classList.add('active');
  window.scrollTo({ top: 0, behavior: 'smooth' });
  showToast('🔄 Ready for a new screening session');
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.style.display = 'flex';
  clearTimeout(t._tm);
  t._tm = setTimeout(() => { t.style.display = 'none'; }, 3000);
}
</script>
</body>
</html>
